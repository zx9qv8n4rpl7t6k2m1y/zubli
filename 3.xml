async function fetchPartsFromLinks(links, label) {
  var parts = [];
  for (var i = 0; i < links.length; i++) {
    loadLabel.textContent = label + ' ' + (i + 1) + '/' + links.length + '...';
    var r = await fetch(links[i]);
    if (!r.ok) throw new Error(label + ' part' + i + ': HTTP ' + r.status + ' - ' + links[i]);
    parts.push(new Uint8Array(await r.arrayBuffer()));

    progressBarEmpty.style.display = "";
    var percent = label === 'Data'
      ? ((i + 1) / links.length) * 40
      : 40 + ((i + 1) / links.length) * 40;
    progressBarFull.style.width = percent + '%';
  }

  var total = parts.reduce(function(s,p){ return s + p.length; }, 0);
  var merged = new Uint8Array(total);
  var off = 0;
  for (var j = 0; j < parts.length; j++) {
    merged.set(parts[j], off);
    off += parts[j].length;
  }
  return merged;
}

function brotliBlobUrl(uint8, filename) {
  var blob = new Blob([uint8], { type:'application/octet-stream' });
  return URL.createObjectURL(blob) + '#' + encodeURIComponent(filename);
}

